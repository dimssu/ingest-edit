# Copy to `.env` and fill in. Never commit `.env`.

# --- App ---
NODE_ENV=development
APP_URL=http://localhost:3000
APP_USER_ID=dev-user-1
LOG_LEVEL=info

# --- Database (MongoDB) ---
# Provided later. Example: mongodb+srv://user:pass@cluster.mongodb.net/ingest-edit
MONGODB_URI=
MONGODB_DB_NAME=ingest_edit

# --- AWS S3 ---
# Provided later.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
# Optional CDN/CloudFront base URL for serving stored objects (else signed URLs are used)
S3_PUBLIC_BASE_URL=

# --- Instagram ingestion ---
# Path to a Netscape-format cookies.txt exported while logged into instagram.com.
# Provided later. The file lives outside the repo (see secrets/).
INSTAGRAM_COOKIES_PATH=./secrets/instagram-cookies.txt

# --- Job queue (in-process) ---
# Max concurrent jobs running on this Node process.
JOB_CONCURRENCY=2

# --- ffmpeg / yt-dlp binaries (override only if not on PATH) ---
# FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
# FFPROBE_PATH=/opt/homebrew/bin/ffprobe
# YT_DLP_PATH=/opt/homebrew/bin/yt-dlp
